generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  password    String
  phone       String?
  avatar      String?
  role        String   @default("user")
  verified    Boolean  @default(false)
  latitude    Float?
  longitude   Float?
  city        String?
  state       String?
  lastLoginAt DateTime?
  lastLoginIp String?
  /// Set true after partner/vendor/developer completes first-time profile details
  onboardingComplete Boolean @default(false)
  /// Role-specific onboarding fields (company, category, etc.)
  profileMeta          Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties   Property[]
  inquiries    Inquiry[]
  favorites    Favorite[]
  reviews      Review[]
  activities   ActivityLog[]
  chatMessages ChatMessage[]
  blogPosts    BlogPost[]
}

model Property {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  price       Float
  type        String
  category    String
  status      String   @default("active")
  bedrooms    Int?
  bathrooms   Int?
  balconies   Int?
  area        Float
  areaUnit    String   @default("sqft")
  floor       String?
  totalFloors String?
  facing      String?
  furnishing  String?
  age         String?
  address     String
  locality    String
  city        String
  state       String
  pincode     String
  latitude    Float?
  longitude   Float?
  images      String   @default("[]")
  amenities   String   @default("[]")
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  premium     Boolean  @default(false)
  views       Int      @default(0)
  ownerId     String   @db.ObjectId
  ownerType   String   @default("owner")

  owner     User       @relation(fields: [ownerId], references: [id])
  inquiries Inquiry[]
  favorites Favorite[]
  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  status     String   @default("pending")
  propertyId String   @db.ObjectId
  userId     String   @db.ObjectId
  userName   String
  userEmail  String
  userPhone  String?

  property Property @relation(fields: [propertyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @db.ObjectId
  propertyId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
}

model Review {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  rating     Int
  comment    String
  userId     String @db.ObjectId
  propertyId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  action    String
  details   String?
  ip        String?
  userAgent String?
  latitude  Float?
  longitude Float?
  city      String?
  page      String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  message   String
  response  String
  sessionId String

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model BlogCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
}

model BlogPost {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  metaTitle  String?
  metaDescription String?
  metaTags   String   @default("[]")
  schemaJson   String?
  canonicalUrl String?
  faqs         String   @default("[]")
  coverImage String?
  category   String   @default("general")
  tags       String   @default("[]")
  /// Shown as author on the public post; falls back to linked user name if empty.
  byline     String?
  authorId   String   @db.ObjectId
  published  Boolean  @default(false)
  views      Int      @default(0)

  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  slug               String   @unique
  description        String
  highlights         String   @default("[]")
  builderName        String
  builderLogo        String?
  location           String
  city               String
  state              String
  reraNumber         String?
  projectStatus      String   @default("under-construction")
  possessionDate     String?
  startingPrice      Float
  priceUnit          String   @default("Lac")
  propertyType       String   @default("residential")
  configurations     String   @default("[]")
  totalArea          String?
  totalUnits         Int?
  images             String   @default("[]")
  amenities          String   @default("[]")
  floorPlans         String   @default("[]")
  locationAdvantages String   @default("[]")
  paymentPlans       String   @default("[]")
  brochureUrl        String?
  featured           Boolean  @default(false)
  verified           Boolean  @default(false)
  views              Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Developer {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String   @unique
  logo             String?
  about            String?
  establishedYear  Int?
  strengths        String   @default("[]")
  partnerOpportunity String?
  operatingCities  String   @default("[]")
  website          String?
  contactEmail     String?
  contactPhone     String?
  featured         Boolean  @default(false)
  verified         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  slug          String   @unique
  state         String
  isPopular     Boolean  @default(false)
  latitude      Float?
  longitude     Float?
  imageUrl      String?
  displayOrder  Int      @default(0)
  isServiceable Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                     String  @id @map("_id")
  siteName               String  @default("Property Pointers")
  siteDescription        String  @default("India's #1 Real Estate Platform")
  contactEmail           String  @default("propertypointersofficial@gmail.com")
  contactPhone           String  @default("+91 92174 34838")
  address                String  @default("701, GDITL NorthEx, Netaji Subhash Place, New Delhi - 110034")
  facebook               String? @default("https://www.facebook.com/share/1CQ4czxaZu/?mibextid=wwXIfr")
  twitter                String?
  instagram              String?
  linkedin               String? @default("https://www.linkedin.com/company/propertypointersofficial/")
  maintenanceMode        Boolean @default(false)
  /// "exact" = count from activity logs; "manual" = show manualActiveVisitors
  activeVisitorsDisplay  String  @default("exact")
  manualActiveVisitors   Int     @default(20)
}

model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  source    String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===========================================================================
// Interactive features backing the client-provided PP_* pages.
// These models power the forms in public/pp/*.html (via public/pp-shell.js).
// ===========================================================================

/// Community Q&A — buyers can post real estate questions, admins/experts answer.
/// Powers PP_COMMUNITY_QA.html.
model CommunityQuestion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  body        String
  category    String   @default("general")
  city        String?
  locality    String?
  authorId    String?  @db.ObjectId
  authorName  String
  authorEmail String?
  /// pending -> approved -> rejected. Only approved shows on public feed.
  status      String   @default("pending")
  featured    Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  answers CommunityAnswer[]
}

model CommunityAnswer {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @db.ObjectId
  body       String
  authorId   String?  @db.ObjectId
  authorName String
  authorRole String   @default("user")
  upvotes    Int      @default(0)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question CommunityQuestion @relation(fields: [questionId], references: [id])
}

/// Society Reviews — reviews of specific residential societies (buildings).
/// Powers PP_SOCIETY_REVIEWS.html.
model SocietyReview {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  societyName   String
  city          String
  locality      String
  builderName   String?
  authorId      String?  @db.ObjectId
  authorName    String
  authorEmail   String?
  ratingOverall Int
  ratingConstr  Int?
  ratingAmen    Int?
  ratingMaint   Int?
  ratingSafety  Int?
  pros          String?
  cons          String?
  comment       String
  yearsResiding Int?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Scam Reporter — public form for flagging fraudulent builders / listings /
/// advisors. Powers PP_SCAM_REPORTER.html and feeds admin triage.
model ScamReport {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  subjectType   String
  subjectName   String
  city          String?
  locality      String?
  incidentDate  DateTime?
  amount        Float?
  currency      String    @default("INR")
  description   String
  evidenceUrls  String    @default("[]")
  reporterName  String
  reporterEmail String
  reporterPhone String?
  anonymous     Boolean   @default(false)
  status        String    @default("pending")
  adminNotes    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Builder Watchlist — authenticated user's saved developers to track.
/// Powers PP_BUILDER_WATCHLIST.html.
model BuilderWatchlistItem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  developerSlug String
  developerName String
  createdAt     DateTime @default(now())

  @@unique([userId, developerSlug])
}

/// Buyer PP Score — a persistent research credibility score per user.
/// Powers PP_BUYER_SCORE.html and PP_BUYER_READINESS_QUIZ.html.
model BuyerScore {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String?  @db.ObjectId
  sessionId     String?
  name          String?
  email         String?
  score         Int
  readinessBand String
  answers       String   @default("[]")
  city          String?
  budget        Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Locality Content — structured data for /localities/[slug] pages.
/// Currently the client HTML is hardcoded; this model lets admins later
/// override / extend individual localities without editing HTML.
model LocalityContent {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  slug              String   @unique
  name              String
  city              String
  state             String
  summary           String?
  avgPricePerSqft   Float?
  yoyGrowthPct      Float?
  rentalYieldPct    Float?
  livabilityScore   Int?
  connectivityScore Int?
  safetyScore       Int?
  socialInfraScore  Int?
  featured          Boolean  @default(false)
  updatedByAdmin    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Locality Request — user request for a new locality guide.
model LocalityRequest {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  city           String
  requesterName  String
  requesterEmail String
  requesterPhone String?
  notes          String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
