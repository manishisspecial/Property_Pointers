generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  password    String
  phone       String?
  avatar      String?
  role        String   @default("user")
  verified    Boolean  @default(false)
  latitude    Float?
  longitude   Float?
  city        String?
  state       String?
  lastLoginAt DateTime?
  lastLoginIp String?
  /// Set true after partner/vendor/developer completes first-time profile details
  onboardingComplete Boolean @default(false)
  /// Role-specific onboarding fields (company, category, etc.)
  profileMeta          Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties   Property[]
  inquiries    Inquiry[]
  favorites    Favorite[]
  reviews      Review[]
  activities   ActivityLog[]
  chatMessages ChatMessage[]
  blogPosts    BlogPost[]
}

model Property {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  price       Float
  type        String
  category    String
  status      String   @default("active")
  bedrooms    Int?
  bathrooms   Int?
  balconies   Int?
  area        Float
  areaUnit    String   @default("sqft")
  floor       String?
  totalFloors String?
  facing      String?
  furnishing  String?
  age         String?
  address     String
  locality    String
  city        String
  state       String
  pincode     String
  latitude    Float?
  longitude   Float?
  images      String   @default("[]")
  amenities   String   @default("[]")
  verified    Boolean  @default(false)
  featured    Boolean  @default(false)
  premium     Boolean  @default(false)
  views       Int      @default(0)
  ownerId     String   @db.ObjectId
  ownerType   String   @default("owner")

  owner     User       @relation(fields: [ownerId], references: [id])
  inquiries Inquiry[]
  favorites Favorite[]
  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    String
  status     String   @default("pending")
  propertyId String   @db.ObjectId
  userId     String   @db.ObjectId
  userName   String
  userEmail  String
  userPhone  String?

  property Property @relation(fields: [propertyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @db.ObjectId
  propertyId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
}

model Review {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  rating     Int
  comment    String
  userId     String @db.ObjectId
  propertyId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  action    String
  details   String?
  ip        String?
  userAgent String?
  latitude  Float?
  longitude Float?
  city      String?
  page      String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  message   String
  response  String
  sessionId String

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model BlogPost {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  metaTitle  String?
  metaDescription String?
  metaTags   String   @default("[]")
  schemaJson String?
  faqs       String   @default("[]")
  coverImage String?
  category   String   @default("general")
  tags       String   @default("[]")
  /// Shown as author on the public post; falls back to linked user name if empty.
  byline     String?
  authorId   String   @db.ObjectId
  published  Boolean  @default(false)
  views      Int      @default(0)

  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  slug               String   @unique
  description        String
  highlights         String   @default("[]")
  builderName        String
  builderLogo        String?
  location           String
  city               String
  state              String
  reraNumber         String?
  projectStatus      String   @default("under-construction")
  possessionDate     String?
  startingPrice      Float
  priceUnit          String   @default("Lac")
  propertyType       String   @default("residential")
  configurations     String   @default("[]")
  totalArea          String?
  totalUnits         Int?
  images             String   @default("[]")
  amenities          String   @default("[]")
  floorPlans         String   @default("[]")
  locationAdvantages String   @default("[]")
  paymentPlans       String   @default("[]")
  brochureUrl        String?
  featured           Boolean  @default(false)
  verified           Boolean  @default(false)
  views              Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Developer {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String   @unique
  logo             String?
  about            String?
  establishedYear  Int?
  strengths        String   @default("[]")
  partnerOpportunity String?
  operatingCities  String   @default("[]")
  website          String?
  contactEmail     String?
  contactPhone     String?
  featured         Boolean  @default(false)
  verified         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  slug          String   @unique
  state         String
  isPopular     Boolean  @default(false)
  latitude      Float?
  longitude     Float?
  imageUrl      String?
  displayOrder  Int      @default(0)
  isServiceable Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                     String  @id @map("_id")
  siteName               String  @default("Property Pointers")
  siteDescription        String  @default("India's #1 Real Estate Platform")
  contactEmail           String  @default("propertypointersofficial@gmail.com")
  contactPhone           String  @default("+91-9990074072")
  address                String  @default("701, GDITL NorthEx, Netaji Subhash Place, New Delhi - 110034")
  facebook               String? @default("https://www.facebook.com/share/1CQ4czxaZu/?mibextid=wwXIfr")
  twitter                String?
  instagram              String?
  linkedin               String? @default("https://www.linkedin.com/company/propertypointersofficial/")
  maintenanceMode        Boolean @default(false)
  /// "exact" = count from activity logs; "manual" = show manualActiveVisitors
  activeVisitorsDisplay  String  @default("exact")
  manualActiveVisitors   Int     @default(20)
}
